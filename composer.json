{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^7.3|^8.0",
        "anhskohbo/no-captcha": "^3.3",
        "ashallendesign/short-url": "^5.1",
        "barryvdh/laravel-dompdf": "^0.9.0",
        "fideloper/proxy": "^4.4",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "haruncpi/laravel-simple-captcha": "^1.0",
        "haruncpi/laravel-user-activity": "^1.0",
        "intervention/image": "^2.6",
        "jhumanj/laravel-model-stats": "^0.1.1",
        "jorenvanhocht/laravel-share": "^4.1",
        "kayandra/hashidable": "^1.6",
        "kwn/number-to-words": "^2.1",
        "laravel-arcanist/arcanist": "^0.5.1",
        "laravel/framework": "^8.40",
        "laravel/tinker": "^2.5",
        "laravel/ui": "^3.3",
        "laraveldaily/laravel-charts": "^0.1.27",
        "livewire/livewire": "^2.5",
        "maatwebsite/excel": "^3.1",
        "multicaret/laravel-acquaintances": "^3.5",
        "nwidart/laravel-modules": "^9.0",
        "protonemedia/laravel-cross-eloquent-search": "^3.0",
        "rs/laravel-version-control": "dev-master",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/crypto": "^2.0",
        "spatie/laravel-sitemap": "^6.1",
        "stancl/tenancy": "^3.4"
    },
    "require-dev": {
        "bennett-treptow/laravel-migration-generator": "^3.2",
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^5.0",
        "phpunit/phpunit": "^9.3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
